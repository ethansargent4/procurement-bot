# --- Postgres (Railway auto-sets this when you add the Postgres plugin) ---
DATABASE_URL=

# --- SAM.gov ---
# Get a key at https://sam.gov → Account → API Key
SAM_API_KEY=

# Broad supply NAICS (comma-separated). Covers wholesale, machinery, vehicle parts, electronics, etc.
NAICS_CODES=332,333,334,335,336,423,811
# Optional Product Service Codes (ccode) — leave empty for any
PSC_CODES=
# Optional keywords to further narrow, e.g. "generator,brake,caliper"
KEYWORDS=
# Optional set-aside types (SBA, WOSB, 8A, SDVOSBC, ...)
SET_ASIDES=
LOOKBACK_DAYS=2
MIN_SCORE=0.3
CRON_SCHEDULE=0 */4 * * *

# --- LLM (required for requirements extraction, quote parsing, bid drafting) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Supplier discovery ---
# Serper web search (https://serper.dev) — free tier is fine to start
SERPER_API_KEY=

# --- Gmail OAuth ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web app)
# Authorized redirect URI: https://<your-railway-domain>/oauth/google/callback (and http://localhost:3000/... for local)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
# Obtained by visiting /oauth/google once, then copying the token shown in the callback page
GOOGLE_REFRESH_TOKEN=
FROM_ADDRESS=you@yourdomain.com
FROM_NAME=Procurement

# --- Bidding guardrails ---
MAX_BID_AMOUNT=100000
DEFAULT_MARGIN_PCT=15

# --- Dashboard ---
# If set, dashboard requires ?key=<this> or Authorization: Bearer <this>
DASHBOARD_PASSWORD=

PORT=3000
